# Scene Studio API Keys
# Copy this file to `.env` and fill in your own values. Never commit `.env`.

# Google Gemini — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Video Generation (fal.ai — wraps Kling 2.6 Pro)
# Get one at https://fal.ai/dashboard/keys
KLING_ACCESS_KEY=

# Legacy/unused — leave blank
KLING_SECRET_KEY=

# Optional: override default project storage location (~/.scene_studio/projects)
# SCENE_STUDIO_DATA_DIR=
